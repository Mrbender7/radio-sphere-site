<!--
  ══════════════════════════════════════════════════════════════════════
  RadioSphere — AndroidManifest.xml Additions (v2.5.2)
  ══════════════════════════════════════════════════════════════════════

  SECTION 1: Permissions (add at <manifest> level, before <application>)
  SECTION 2: Application components (add inside <application> tag)

  IMPORTANT: <application> tag MUST include android:appCategory="audio"
-->

<!-- ═══════════════════════════════════════════════════════════════════
     SECTION 1: Permissions (at <manifest> level)
     ═══════════════════════════════════════════════════════════════════ -->

<!-- Réseau de base -->
<uses-permission android:name="android.permission.INTERNET" />
<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
<uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
<uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

<!-- Découverte réseau local (Cast SDK) -->
<uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

<!-- Android 13+ : obligatoire pour découverte mDNS/Cast -->
<uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
    android:usesPermissionFlags="neverForLocation" />

<!-- Services & notifications -->
<uses-permission android:name="android.permission.WAKE_LOCK" />
<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
<uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

<!-- ═══════════════════════════════════════════════════════════════════
     SECTION 2: Inside <application> tag
     Add these attributes to the <application> tag:
       android:appCategory="audio"
       android:allowBackup="false"
       android:fullBackupContent="false"
     ═══════════════════════════════════════════════════════════════════ -->

<!-- 1. Android Auto metadata — tells Android this is a media app -->
<meta-data
    android:name="com.google.android.gms.car.application"
    android:resource="@xml/automotive_app_desc" />

<!-- 2. RadioBrowserService — UNIQUE service: Android Auto + notifications -->
<service
    android:name=".RadioBrowserService"
    android:exported="true"
    android:enabled="true"
    android:foregroundServiceType="mediaPlayback"
    android:label="@string/app_name"
    android:icon="@mipmap/ic_launcher">
    <intent-filter>
        <action android:name="android.media.browse.MediaBrowserService" />
    </intent-filter>
</service>

<!-- Android Auto notification icon -->
<meta-data
    android:name="com.google.android.gms.car.notification.SmallIcon"
    android:resource="@drawable/ic_notification" />

<!-- 3. Chromecast — CastOptionsProvider (OBLIGATOIRE pour Cast SDK) -->
<meta-data
    android:name="com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME"
    android:value="com.radiosphere.app.CastOptionsProvider" />

<!-- 4. Broadcast receiver for notification toggle (unified) -->
<receiver
    android:name=".MediaToggleReceiver"
    android:exported="false">
    <intent-filter>
        <action android:name="com.radiosphere.TOGGLE_PLAYBACK" />
    </intent-filter>
</receiver>

<!--
  ══════════════════════════════════════════════════════════════════════
  NOTE: MediaPlaybackService has been REMOVED (v2.5.2).
  RadioBrowserService handles both Android Auto and standard notifications.

  Register plugins in your MainActivity.kt/java:
    registerPlugin(RadioAutoPlugin.class);
    registerPlugin(CastPlugin.class);
  ══════════════════════════════════════════════════════════════════════
-->
